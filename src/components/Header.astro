---
import { navigation } from "@/data/site";

const isHomePage = Astro.url.pathname === "/";
const brandHref = isHomePage ? "#top" : "/";
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={brandHref} aria-label="Zur Startseite">
      <span class="brand-mark" aria-hidden="true">
        <img src="/logo-header-footer.png" alt="" width="72" height="72" />
      </span>
      <div class="brand-copy">
        <span class="brand-kicker">islamische</span>
        <span class="brand-name">Literatur</span>
      </div>
    </a>

    <nav class="nav" aria-label="Hauptnavigation">
      <ul>
        {
          navigation.map((item) => (
            <li>
              <a href={isHomePage ? item.href : `/${item.href}`}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
